{
  "name": "render-mcp",
  "version": "0.1.0",
  "description": "MCP server for rendering PDFs, HTML, URLs, and images as screenshots",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "render-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "render",
    "screenshot",
    "pdf",
    "playwright"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LarsenClose/render-mcp.git"
  },
  "homepage": "https://github.com/LarsenClose/render-mcp#readme",
  "bugs": {
    "url": "https://github.com/LarsenClose/render-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@resvg/resvg-js": "^2.6.2",
    "pdfjs-dist": "^5.5.207",
    "playwright": "^1.50.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
